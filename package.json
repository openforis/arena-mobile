    "re-reselect": "^4.0.1",
    "react": "17.0.2",
    "react-i18next": "^11.18.1",
    "react-native": "0.67.3",
    "react-native-camera": "^4.2.1",
    "react-native-date-picker": "^4.2.5",
    "react-native-document-picker": "^8.1.1",
    "react-native-elements": "^3.4.2",
    "react-native-fs": "^2.20.0",
