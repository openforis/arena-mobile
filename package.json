    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "TZ=UTC jest",
    "test-coverage": "TZ=UTC jest --coverage",
    "lint": "eslint .",
    "prepare": "husky install"
  },
  "dependencies": {
    "@openforis/arena-core": "^0.0.107",
    "@react-native-community/datetimepicker": "^6.2.2",
