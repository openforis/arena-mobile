    "react-native-zip-archive": "^6.0.8",
    "react-redux": "^8.0.2",
    "redux": "^4.2.0",
    "redux-actions": "^2.6.5",
    "redux-devtools-extension": "^2.13.9",
    "redux-persist": "^6.0.0",
    "redux-saga": "^1.1.3",
    "remote-redux-devtools": "^0.5.16",
    "reselect": "^4.1.6",
    "socket.io-client": "^4.5.1",
    "uuid": "^8.3.2"
